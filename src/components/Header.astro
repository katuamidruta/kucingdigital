---
import DarkModeToggle from './DarkModeToggle.astro';

const links = [
  { href: '/log',   label: 'log' },
  { href: '/about', label: 'about' },
];

const { pathname } = Astro.url;

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header>
  <div class="inner">
    <a href="/" class="brand" aria-label="kucing digital">
      <img class="logo-light" src="/logo-light.png" alt="kucing digital" width="75" height="75" />
      <img class="logo-dark"  src="/logo-dark.png"  alt="kucing digital" width="75" height="75" />
    </a>
    <nav>
      {links.map(link => (
        <a href={link.href} class={isActive(link.href) ? 'active' : undefined}>
          [ {link.label} ]
        </a>
      ))}
    </nav>
    <DarkModeToggle />
  </div>
</header>

<style>
  header {
    padding-bottom: 1.25rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .inner {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .brand {
    margin-right: auto;
    display: flex;
    align-items: center;
    text-decoration: none;
    min-width: 0;
  }

  .brand img {
    width: 80px;
    height: 80px;
    border-radius: 4px;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .logo-dark {
    display: none;
  }

  :global(.dark) .logo-light {
    display: none;
  }

  :global(.dark) .logo-dark {
    display: block;
  }

  .brand:hover img {
    opacity: 0.75;
    transform: scale(0.96);
  }

  nav {
    display: flex;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  nav a {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.2s ease;
    position: relative;
  }

  nav a::after {
    content: '';
    position: absolute;
    bottom: 8px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--purple);
    transition: width 0.2s ease;
  }

  nav a:hover::after,
  nav a.active::after {
    width: 100%;
  }

  nav a:hover,
  nav a.active {
    color: var(--purple);
  }

  @media (max-width: 480px) {
    .inner {
      gap: 0.75rem;
    }

    .brand img {
      width: 50px;
      height: 50px;
    }

    nav {
      gap: 0.5rem;
    }

    nav a {
      font-size: 0.85rem;
    }
  }

</style>

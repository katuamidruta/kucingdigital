---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  type: string;
}

const { title, date, type } = Astro.props;

const dateStr = date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<BaseLayout title={`${title} — kucing digital`}>
  <main>
    <header>
      <p class="type-label">{type}</p>
      <h1>{title}</h1>
      <p class="meta">{dateStr}</p>
    </header>

    <article>
      <slot />
    </article>

    <footer>
      <nav>
        <a href={`/${type}`}>[ {type} ]</a>
        <a href="/log">[ all ]</a>
        <a href="/">[ home ]</a>
      </nav>
    </footer>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 660px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 3.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .type-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 1rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 400;
    line-height: 2;
    margin-bottom: 0.75rem;
    word-break: break-word;
  }

  .meta {
    font-size: 0.75rem;
    color: var(--muted);
  }

  article {
    margin-bottom: 5rem;
    font-size: 0.95rem;
    line-height: 1.9;
  }

  article :global(p) {
    margin-bottom: 1.5rem;
  }

  article :global(h2) {
    font-family: var(--font-display);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 3rem 0 1rem;
  }

  article :global(h3) {
    font-family: var(--font-display);
    font-size: 0.6rem;
    color: var(--muted);
    margin: 2rem 0 0.75rem;
  }

  article :global(strong) {
    font-weight: 600;
  }

  article :global(em) {
    font-style: italic;
    color: var(--muted);
  }

  article :global(blockquote) {
    border-left: 2px solid var(--purple);
    padding-left: 1.25rem;
    margin: 2.5rem 0;
    color: var(--muted);
    font-style: italic;
  }

  article :global(blockquote p) {
    margin-bottom: 0;
  }

  article :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  article :global(img) {
    border-radius: 4px;
    margin: 2.5rem 0;
  }

  footer {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  nav {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  nav a {
    font-size: 1.1rem;
    color: var(--muted);
    text-decoration: none;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  nav a:hover {
    color: var(--purple);
  }

  @media (max-width: 480px) {
    nav { gap: 1.5rem; }
    nav a { font-size: 0.9rem; }
  }
</style>

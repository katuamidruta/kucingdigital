---
interface Props {
  title?: string;
}

const { title = 'Oktaviary Log' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 18px;
  }

  body {
    font-family: Georgia, 'Times New Roman', serif;
    line-height: 1.7;
    color: #1a1a1a;
    background: #fafafa;
    padding: 2rem 1rem;
  }

  a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  a:hover {
    color: #555;
  }
</style>

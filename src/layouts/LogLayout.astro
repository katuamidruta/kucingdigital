---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  type: string;
  logNumber?: number;
}

const { title, date, type, logNumber } = Astro.props;

const dateFormatted = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const logLabel = logNumber !== undefined
  ? `Log ${String(logNumber).padStart(3, '0')}`
  : null;
---

<BaseLayout title={`${title} — Oktaviary Log`}>
  <main>
    <header>
      {logLabel && <p class="lognumber">{logLabel}</p>}
      <h1>{title}</h1>
      <p class="meta">{dateFormatted} · {type}</p>
    </header>

    <article>
      <slot />
    </article>

    <footer>
      <a href="/log">← Log</a>
    </footer>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 3rem;
  }

  .lognumber {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  h1 {
    font-size: 1.8rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 0.6rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  article {
    margin-bottom: 4rem;
  }

  article :global(p) {
    margin-bottom: 1.4rem;
  }

  article :global(h2) {
    font-size: 1.25rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  article :global(h3) {
    font-size: 1.05rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  article :global(strong) {
    font-weight: 600;
  }

  article :global(em) {
    font-style: italic;
  }

  article :global(blockquote) {
    border-left: 2px solid var(--border);
    padding-left: 1.25rem;
    color: var(--accent);
    margin: 2rem 0;
    font-style: italic;
  }

  article :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  article :global(img) {
    border-radius: 4px;
    margin: 2rem 0;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  article :global(img:hover) {
    transform: scale(1.02);
    filter: brightness(1.04);
  }

  footer {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  footer a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  footer a:hover {
    color: var(--text);
  }
</style>

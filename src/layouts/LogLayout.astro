---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  type: string;
  logNumber?: number;
}

const { title, date, type, logNumber } = Astro.props;

const dateFormatted = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const logLabel = logNumber !== undefined
  ? `Log ${String(logNumber).padStart(3, '0')}`
  : null;
---

<BaseLayout title={`${title} — Oktaviary Log`}>
  <main>
    <header>
      {logLabel && <p class="lognumber">{logLabel}</p>}
      <h1>{title}</h1>
      <p class="meta">{dateFormatted} · {type}</p>
    </header>

    <article>
      <slot />
    </article>

    <footer>
      <a href="/log">← Log</a>
    </footer>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 3rem;
  }

  .lognumber {
    font-family: monospace;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: #888;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: normal;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .meta {
    font-size: 0.85rem;
    color: #888;
  }

  article {
    margin-bottom: 4rem;
  }

  article :global(p) {
    margin-bottom: 1.25rem;
  }

  article :global(h2),
  article :global(h3) {
    font-weight: normal;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  article :global(strong) {
    font-weight: bold;
  }

  article :global(blockquote) {
    border-left: 2px solid #ccc;
    padding-left: 1rem;
    color: #555;
    margin: 1.5rem 0;
  }

  footer {
    border-top: 1px solid #e5e5e5;
    padding-top: 1.5rem;
  }

  footer a {
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
  }

  footer a:hover {
    color: #1a1a1a;
  }
</style>

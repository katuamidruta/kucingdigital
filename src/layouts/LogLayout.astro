---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  type: string;
  nextSlug?: string | null;
}

const { title, date, type, nextSlug } = Astro.props;

const dateFormatted = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={`${title} — kucing digital`}>
  <main>
    <header>
      <h1>{title}</h1>
      <p class="meta">{dateFormatted} · {type}</p>
    </header>

    <article>
      <slot />
    </article>

    <footer>
      <nav class="back-nav">
        <a href="/log">[ back ]</a>
        <a href="/">[ home ]</a>
        {nextSlug && <a href={`/log/${nextSlug}`}>[ next ]</a>}
      </nav>
    </footer>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 3rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.8;
    letter-spacing: 0;
    margin-bottom: 0.6rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  article {
    margin-bottom: 4rem;
  }

  article :global(p) {
    margin-bottom: 1.4rem;
  }

  article :global(h2) {
    font-family: var(--font-display);
    font-size: 0.8rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  article :global(h3) {
    font-family: var(--font-display);
    font-size: 0.65rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  article :global(strong) {
    font-weight: 600;
  }

  article :global(em) {
    font-style: italic;
  }

  article :global(blockquote) {
    border-left: 2px solid var(--purple);
    padding-left: 1.25rem;
    color: var(--muted);
    margin: 2rem 0;
    font-style: italic;
  }

  article :global(blockquote p) {
    margin-bottom: 0;
  }

  article :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  article :global(iframe) {
    margin: 2rem 0;
    border-radius: 4px;
    display: block;
  }

  article :global(img) {
    border-radius: 4px;
    margin: 2rem 0;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  @media (hover: hover) {
    article :global(img:hover) {
      transform: scale(1.02);
      filter: brightness(1.04);
    }
  }

  /* writing log entries */
  article :global(.writing-log) {
    background: #0d0d0d;
    padding: 24px;
    border-radius: 16px;
    border: 1px solid #222;
    margin: 2rem 0;
  }

  article :global(.writing-title) {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }

  article :global(.writing-content) {
    color: #aaa;
    font-size: 0.9rem;
    line-height: 1.8;
    white-space: pre-line;
  }

  /* music log entries */
  article :global(.music-log) {
    background: #0d0d0d;
    padding: 20px;
    border-radius: 16px;
    border: 1px solid #222;
    margin: 2rem 0;
  }

  article :global(.music-title) {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }

  article :global(.music-caption) {
    color: #aaa;
    font-size: 0.85rem;
    line-height: 1.7;
    margin-bottom: 1rem;
    white-space: pre-line;
  }

  article :global(.music-log iframe) {
    display: block;
    border-radius: 8px;
    margin: 0;
  }

  footer {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .back-nav {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .back-nav a {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  .back-nav a:hover {
    color: var(--purple);
  }

  @media (max-width: 480px) {
    .back-nav {
      gap: 1.5rem;
    }

    .back-nav a {
      font-size: 1rem;
    }

    h1 {
      font-size: 0.85rem;
    }
  }
</style>

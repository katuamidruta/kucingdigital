---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Typewriter from '../components/Typewriter.astro';

const allLogs = (await getCollection('logs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest      = allLogs.slice(0, 6);
const writing     = allLogs.find((e) => e.data.type === 'writing');
const mix         = allLogs.find((e) => e.data.type === 'mix');
const conversations = allLogs.filter((e) => e.data.type === 'conversation').slice(0, 3);

function shortDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout>
  <div class="page">

    <header class="site-header">
      <h1>Oktaviary Log</h1>
      <Typewriter
        class="tagline"
        segments={[
          "Now I wonder:",
          "Am I a man who dreamt of being a cat,",
          "or am I a cat dreaming that I am a man."
        ]}
      />
    </header>

    <section>
      <h2>Latest</h2>
      <ul class="log-list">
        {latest.map((entry) => (
          <li>
            <a href={`/log/${entry.id}`}>{entry.data.title}</a>
            <span class="row-meta">{entry.data.type} · {shortDate(entry.data.date)}</span>
          </li>
        ))}
      </ul>
      <a class="view-all" href="/log">All entries →</a>
    </section>

    <div class="highlights">
      {writing && (
        <section class="highlight">
          <h2>Writing</h2>
          <a class="highlight-title" href={`/log/${writing.id}`}>{writing.data.title}</a>
          <p class="highlight-desc">{writing.data.description}</p>
          <p class="row-meta">{shortDate(writing.data.date)}</p>
        </section>
      )}

      {mix && (
        <section class="highlight">
          <h2>Mix</h2>
          <a class="highlight-title" href={`/log/${mix.id}`}>{mix.data.title}</a>
          <p class="highlight-desc">{mix.data.description}</p>
          <p class="row-meta">{shortDate(mix.data.date)}</p>
        </section>
      )}
    </div>

    {conversations.length > 0 && (
      <section>
        <h2>Conversations</h2>
        <ul class="log-list">
          {conversations.map((entry) => (
            <li>
              <a href={`/log/${entry.id}`}>{entry.data.title}</a>
              <span class="row-meta">{shortDate(entry.data.date)}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .page {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .site-header h1 {
    font-size: 1.75rem;
    font-weight: normal;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .tagline {
    font-size: 0.9rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  h2 {
    font-size: 0.7rem;
    font-weight: normal;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .log-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .log-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 0;
    transition: background 0.15s ease;
  }

  .log-list li:first-child {
    border-top: 1px solid var(--border);
  }

  .log-list a {
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    width: 100%;
    transition: color 0.2s ease;
  }

  .log-list a:hover {
    color: var(--purple);
  }

  .log-list a:hover .row-meta {
    color: var(--purple);
    opacity: 0.7;
  }

  .row-meta {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .view-all:hover {
    color: var(--purple);
  }

  .highlights {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .highlight {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .highlight-title {
    display: block;
    font-size: 1.05rem;
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.2s ease;
  }

  .highlight-title:hover {
    color: var(--purple);
  }

  .highlight-desc {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .highlights {
      grid-template-columns: 1fr;
    }

    .log-list li {
      flex-direction: column;
      gap: 0.2rem;
    }

    .row-meta {
      white-space: normal;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const logs = (await getCollection('logs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<BaseLayout title="Log — log: oktaviary">
  <main>
    <header>
      <h1>Log</h1>
    </header>

    <nav class="back-nav">
      <a href="/">[ home ]</a>
    </nav>

    <ul>
      {logs.map((log) => (
        <li>
          <a href={`/log/${log.id}`}>
            <span class="title">{log.data.title}</span>
            <span class="meta">{formatDate(log.data.date)} · {log.data.type}</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
  }

  .back-nav {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }

  .back-nav a {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .back-nav a:hover {
    color: var(--purple);
  }

  header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: normal;
  }

  ul {
    list-style: none;
  }

  li {
    border-top: 1px solid var(--border);
    padding: 1rem 0;
    transition: border-color 0.2s ease;
  }

  li:last-child {
    border-bottom: 1px solid var(--border);
  }

  a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    flex-wrap: wrap;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--purple);
  }

  a:hover .meta {
    color: var(--purple);
    opacity: 0.6;
  }

  .title {
    color: var(--text);
    transition: color 0.2s ease;
  }

  a:hover .title {
    color: var(--purple);
  }

  .meta {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
</style>

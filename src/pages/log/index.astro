---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const logs = (await getCollection('logs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const types = ['writing', 'mix', 'review', 'conversation', 'experiment'];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<BaseLayout title="Log — kucing digital">
  <main>
    <header>
      <h1>Log</h1>
    </header>

    <nav class="back-nav">
      <a href="/">[ home ]</a>
    </nav>

    <nav class="type-filter">
      <a href="/log">all</a>
      {types.map(t => <a href={`/log?type=${t}`}>{t}</a>)}
    </nav>

    <ul>
      {logs.map((log) => (
        <li data-type={log.data.type}>
          <a href={`/log/${log.data.slug ?? log.id}`}>
            <span class="title">{log.data.title}</span>
            <span class="meta">{formatDate(log.data.date)} · {log.data.type}</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<script>
  const params = new URLSearchParams(location.search);
  const active = params.get('type');

  document.querySelectorAll<HTMLElement>('[data-type]').forEach(el => {
    el.hidden = !!active && el.dataset.type !== active;
  });

  document.querySelectorAll<HTMLAnchorElement>('.type-filter a').forEach(a => {
    const t = new URL(a.href).searchParams.get('type');
    if (t === active || (!t && !active)) a.classList.add('active');
  });
</script>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
  }

  .back-nav {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }

  .back-nav a {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .back-nav a:hover {
    color: var(--purple);
  }

  header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: normal;
  }

  .type-filter {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .type-filter a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .type-filter a:hover,
  .type-filter a.active {
    color: var(--purple);
  }

  ul {
    list-style: none;
  }

  li {
    border-top: 1px solid var(--border);
    padding: 1rem 0;
    transition: border-color 0.2s ease;
  }

  li:last-child {
    border-bottom: 1px solid var(--border);
  }

  a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    flex-wrap: wrap;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--purple);
  }

  a:hover .meta {
    color: var(--purple);
    opacity: 0.6;
  }

  .title {
    color: var(--text);
    transition: color 0.2s ease;
  }

  a:hover .title {
    color: var(--purple);
  }

  .meta {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
</style>

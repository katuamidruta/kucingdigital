---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const logs = (await getCollection('logs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function formatLogNumber(n: number) {
  return `Log ${String(n).padStart(3, '0')}`;
}
---

<BaseLayout title="Log — Oktaviary Log">
  <main>
    <header>
      <h1>Log</h1>
    </header>

    <nav class="back-nav">
      <a href="/">[ home ]</a>
    </nav>

    <ul>
      {logs.map((entry) => (
        <li>
          <a href={`/log/${entry.id}`}>
            <span class="title">
              {entry.data.logNumber && (
                <span class="lognumber">{formatLogNumber(entry.data.logNumber)} — </span>
              )}
              {entry.data.title}
            </span>
            <span class="meta">{formatDate(entry.data.date)} · {entry.data.type}</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
  }

  .back-nav {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }

  .back-nav a {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .back-nav a:hover {
    color: var(--purple);
  }

  header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: normal;
  }

  ul {
    list-style: none;
  }

  li {
    border-top: 1px solid var(--border);
    padding: 1rem 0;
  }

  li:last-child {
    border-bottom: 1px solid var(--border);
  }

  a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
  }

  a:hover .title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .title {
    color: var(--text);
  }

  .lognumber {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }

  .meta {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>

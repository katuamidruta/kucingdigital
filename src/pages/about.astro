---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — log: oktaviary">
  <div class="page">

    <nav class="back-nav">
      <a href="/">[ home ]</a>
    </nav>

    <div class="block">
      <pre class="text">────────────────────────

<span class="heading">WHERE ARE YOUR FEELINGS?</span>

locate them.

do not analyse.
locate.

—

are they in your chest,
your stomach,
your lungs?

—

do not analyse...

locate.

────────────────────────</pre>
    </div>

  </div>
</BaseLayout>

<style>
  .page {
    max-width: 700px;
    margin: 0 auto;
  }

  .back-nav {
    display: flex;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .back-nav a {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }

  .back-nav a:hover {
    color: var(--purple);
  }

  .block {
    padding-left: 2rem;
  }

  .text {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 2;
    color: var(--muted);
    white-space: pre;
    background: none;
    border: none;
    margin: 0;
    padding: 0;
    max-width: 480px;
    text-align: left;
    overflow-x: auto;
  }

  .heading {
    color: var(--text);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  @media (max-width: 480px) {
    .block {
      padding-left: 0;
    }

    .text {
      font-size: 0.82rem;
    }
  }
</style>
